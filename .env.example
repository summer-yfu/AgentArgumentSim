# Copy to `.env` (gitignored). Do not commit real keys.

# --- ConnectOnion / OpenOnion (model access; often written by `co auth`) ---
# OPENONION_API_KEY=
# AGENT_EMAIL=
# AGENT_ADDRESS=
# AGENT_CONFIG_PATH=

# --- Optional: Chroma / RAG embeddings (must match how you ran build_index) ---
# OPENAI_API_KEY=
# USE_LOCAL_EMBEDDINGS=1

# --- Optional: process logging (Python logging module level name) ---
# LOG_LEVEL=INFO
